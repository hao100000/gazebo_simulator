      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin rpy="-0.7071 0 -0.5" xyz="0 0 0"/>
      <geometry>
