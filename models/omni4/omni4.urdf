  <!-- まずはwheel_front_leftについてのみ考える -->
  <!-- 目標：車輪とモーターの接続部分が最初(-1,-1,0)方向(ベクトル)を向いて、(-1,-1,0)軸回転。 -->
  <!-- (r, p, yaw, axis_x, axis_y, axis_z) = (0, 0, 0, 0, 0, 1)のとき、接続部分が最初(0, 0, -1)方向を向いて、(0, 0, 1)軸回転 -->
  <!-- (r, p, yaw, axis_x, axis_y, axis_z) = (1.570796, 0, 0, 0, 0, 1)のとき、接続部分が最初(0, 0, 1)方向を向いて、(0, -1, 0)軸回転 -->
  <!-- (r, p, yaw, axis_x, axis_y, axis_z) = (0.785398, 0, 0, 0, 0, 1)のとき、接続部分が最初(0, 1, 0)方向を向いて、(0, -1, 1)軸回転 -->
  <!-- (r, p, yaw, axis_x, axis_y, axis_z) = (-0.785398, 0, -0.5, 0, 0, 1)のとき、接続部分が最初(-1, -1, 0)方向を向いて、(1, 1, 1)軸回転 -->
  <!-- (r, p, yaw, axis_x, axis_y, axis_z) = (1.5708, 0, -2.35619, 0, 0, 1)のとき、接続部分が最初(-1, -1, -1)方向を向いて、(-1, 1, 0)軸回転 -->
  <!-- r="0" p="1.5708" yaw="-2.35619" axis_x="-0.7071" axis_y="-0.7071" axis_z="0"のとき、接続部分が最初(1, -1, -1)方向を向いて、(-1, 1, 1)を軸に回転 -->
  <!-- r="0" p="1.5708" yaw="-2.3561" axis_x="0" axis_y="0" axis_z="1"のとき、接続部分が最初(1, -1, -1)方向を向いて、(-1, -1, 0)を軸に回転 -->
  <!-- r="0" p="0" yaw="-2.3561" axis_x="0" axis_y="0" axis_z="1"のとき、接続部分が最初(0, 0, -1)方向を向いて、(0, 0, 1)を軸に回転 -->
  <!-- r="0" p="-1.5708" yaw="-2.3561" axis_x="0" axis_y="0" axis_z="1"のとき、接続部分が最初(-1, 1, -1)方向を向いて、(-1, -1, 0)を軸に回転 -->
  <!-- Create four wheels using meshes from sim2_lecture if available
  <xacro:odm_visual_wheel name="wheel_front_left" x="${wheel_x}" y="${wheel_y}" r="1.570796" p="0" yaw="0.7854" mesh_housing="model://omni4/meshes/omni_housing.stl" mesh_barrel="model://omni4/meshes/omni_barrel.stl"/>
  <xacro:odm_visual_wheel name="wheel_front_right" x="${wheel_x}" y="-${wheel_y}" r="1.570796" p="0" yaw="-0.7854" mesh_housing="model://omni4/meshes/omni_housing.stl" mesh_barrel="model://omni4/meshes/omni_barrel.stl"/>
  <xacro:odm_visual_wheel name="wheel_rear_left" x="-${wheel_x}" y="${wheel_y}" r="-1.570796" p="0" yaw="2.3562" mesh_housing="model://omni4/meshes/omni_housing.stl" mesh_barrel="model://omni4/meshes/omni_barrel.stl"/>
  <xacro:odm_visual_wheel name="wheel_rear_right" x="-${wheel_x}" y="-${wheel_y}" r="-1.570796" p="0" yaw="-2.3562" mesh_housing="model://omni4/meshes/omni_housing.stl" mesh_barrel="model://omni4/meshes/omni_barrel.stl"/> -->
  <!-- ros2_control plugin config (keep velocity interfaces compatible with existing controllers) -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="wheel_front_left_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel_front_right_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel_rear_left_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel_rear_right_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
