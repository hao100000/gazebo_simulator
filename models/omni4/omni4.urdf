  <link name="base_link">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.3 0.2 0.06"/>
      </geometry>
      <material name="base_material">
        <!-- <color rgba="0.8 0.8 0.8 1"/> -->
        <!-- ↓透明化↑普通 -->
        <color rgba="1 1 1 0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.2 0.06"/>
      </geometry>
    </collision>
  </link>
  <!-- controlled rotor link -->
  <link name="wheel_front_left_link">
    <inertial>
