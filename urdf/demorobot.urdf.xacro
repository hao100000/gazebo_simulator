<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="demorobot">

  <!-- Parameters -->
  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="wheel_length" value="0.018"/>
  <xacro:property name="wheel_separation" value="0.19"/>
  <xacro:property name="base_mass" value="1.3729096"/>
  <xacro:property name="wheel_mass" value="0.1"/>
  <xacro:property name="caster_mass" value="0.001"/>

  <!-- Base link -->
  <link name="base_link">
    <inertial>
      <pose>0.1 0 0 0 0 0</pose>
      <mass value="${base_mass}"/>
      <inertia>
        <ixx>4.2111447e-02</ixx>
        <ixy>0</ixy>
        <ixz>0</ixz>
        <iyy>4.2111447e-02</iyy>
        <iyz>0</iyz>
        <izz>7.5254874e-02</izz>
      </inertia>
    </inertial>
    <collision name="base_collision">
      <pose>-0.064 0.08 0.06 0 0 -1.57</pose>
      <geometry>
        <mesh>
          <uri>model://meshes/2DRoboPrac.stl</uri>
        </mesh>
      </geometry>
    </collision>
    <visual name="base_visual">
      <pose>-0.064 0.08 0.06 0 0 -1.57</pose>
      <geometry>
        <mesh>
          <uri>model://meshes/2DRoboPrac.dae</uri>
        </mesh>
      </geometry>
      <material>
        <color rgba="0.921568627 0.925490196 0.941176471 1"/>
      </material>
    </visual>
  </link>

  <!-- Left wheel -->
  <link name="wheel_left_link">
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia>
        <ixx>1.1175580e-05</ixx>
        <ixy>-4.2369783e-11</ixy>
        <ixz>-5.9381719e-09</ixz>
        <iyy>1.1192413e-05</iyy>
        <iyz>-1.4400107e-11</iyz>
        <izz>2.0712558e-05</izz>
      </inertia>
    </inertial>
    <collision name="wheel_left_collision">
      <geometry>
        <cylinder>
          <radius>${wheel_radius}</radius>
          <length>${wheel_length}</length>
        </cylinder>
      </geometry>
    </collision>
    <visual name="wheel_left_visual">
      <geometry>
        <cylinder>
          <radius>${wheel_radius}</radius>
          <length>${wheel_length}</length>
        </cylinder>
      </geometry>
      <material>
        <color rgba="1.0 0.0 0.0 1"/>
      </material>
    </visual>
  </link>

  <joint name="wheel_left_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.0 0.095 0.023" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-3.14159" upper="3.14159"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- Right wheel -->
  <link name="wheel_right_link">
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia>
        <ixx>1.1175580e-05</ixx>
        <ixy>-4.2369783e-11</ixy>
        <ixz>-5.9381719e-09</ixz>
        <iyy>1.1192413e-05</iyy>
        <iyz>-1.4400107e-11</iyz>
        <izz>2.0712558e-05</izz>
      </inertia>
    </inertial>
    <collision name="wheel_right_collision">
      <geometry>
        <cylinder>
          <radius>${wheel_radius}</radius>
          <length>${wheel_length}</length>
        </cylinder>
      </geometry>
    </collision>
    <visual name="wheel_right_visual">
      <geometry>
        <cylinder>
          <radius>${wheel_radius}</radius>
          <length>${wheel_length}</length>
        </cylinder>
      </geometry>
      <material>
        <color rgba="1.0 0.0 0.0 1"/>
      </material>
    </visual>
  </link>

  <joint name="wheel_right_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.0 -0.095 0.023" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-3.14159" upper="3.14159"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- Caster wheels (back right) -->
  <link name="caster_back_right_link">
    <inertial>
      <mass value="${caster_mass}"/>
      <inertia>
        <ixx>0.00001</ixx>
        <ixy>0.000</ixy>
        <ixz>0.000</ixz>
        <iyy>0.00001</iyy>
        <iyz>0.000</iyz>
        <izz>0.00001</izz>
      </inertia>
    </inertial>
    <collision name="caster_back_right_collision">
      <geometry>
        <sphere>
          <radius>0.005</radius>
        </sphere>
      </geometry>
    </collision>
    <visual name="caster_back_right_visual">
      <geometry>
        <sphere>
          <radius>0.005</radius>
        </sphere>
      </geometry>
      <material>
        <color rgba="0.0 1.0 0.0 1"/>
      </material>
    </visual>
  </link>

  <joint name="caster_back_right_joint" type="ball">
    <parent link="base_link"/>
    <child link="caster_back_right_link"/>
    <origin xyz="0.15 -0.05 -0.004" rpy="-1.57 0 0"/>
  </joint>

  <!-- Caster wheels (back left) -->
  <link name="caster_back_left_link">
    <inertial>
      <mass value="${caster_mass}"/>
      <inertia>
        <ixx>0.00001</ixx>
        <ixy>0.000</ixy>
        <ixz>0.000</ixz>
        <iyy>0.00001</iyy>
        <iyz>0.000</iyz>
        <izz>0.00001</izz>
      </inertia>
    </inertial>
    <collision name="caster_back_left_collision">
      <geometry>
        <sphere>
          <radius>0.005</radius>
        </sphere>
      </geometry>
    </collision>
    <visual name="caster_back_left_visual">
      <geometry>
        <sphere>
          <radius>0.005</radius>
        </sphere>
      </geometry>
      <material>
        <color rgba="0.0 1.0 0.0 1"/>
      </material>
    </visual>
  </link>

  <joint name="caster_back_left_joint" type="ball">
    <parent link="base_link"/>
    <child link="caster_back_left_link"/>
    <origin xyz="0.15 0.05 -0.004" rpy="-1.57 0 0"/>
  </joint>

  <!-- ros2_control plugin config -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="wheel_left_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wheel_right_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
