<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="omni_robot">
  <xacro:include filename="$(find gazebo_simulator)/models/omni_robot/omni_common.xacro"/>
  <xacro:include filename="$(find gazebo_simulator)/models/omni_robot/omni_wheel.xacro"/>

  <!-- per-wheel mounting angles (degrees) - change these to reposition wheels easily -->
  <xacro:property name="wheel0_angle_deg" value="-45"/>
  <xacro:property name="wheel1_angle_deg" value="45"/>
  <xacro:property name="wheel2_angle_deg" value="135"/>
  <xacro:property name="wheel3_angle_deg" value="225"/>

  <link name="base_link"/>

  <joint name="body_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="body_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
  <link name="body_link">
    <visual>
      <geometry>
        <box size="0.14 0.08 0.02" />
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.14 0.08 0.02" />
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>  
  </link>

  <joint name="wheel0_attach_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="wheel0_attach_link"/>
    <origin xyz="${0.07*cos(radians(wheel0_angle_deg))} ${0.07*sin(radians(wheel0_angle_deg))} 0.019" rpy="0 0 ${radians(wheel0_angle_deg)}"/>
  </joint>
  <link name="wheel0_attach_link" />
  <xacro:omni_wheel_set prefix="wheel0" parent="wheel0_attach_link" />

  <joint name="wheel1_attach_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="wheel1_attach_link"/>
    <origin xyz="${0.07*cos(radians(wheel1_angle_deg))} ${0.07*sin(radians(wheel1_angle_deg))} 0.019" rpy="0 0 ${radians(wheel1_angle_deg)}"/>
  </joint>
  <link name="wheel1_attach_link" />
  <xacro:omni_wheel_set prefix="wheel1" parent="wheel1_attach_link" />

  <joint name="wheel2_attach_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="wheel2_attach_link"/>
    <origin xyz="${0.07*cos(radians(wheel2_angle_deg))} ${0.07*sin(radians(wheel2_angle_deg))} 0.019" rpy="0 0 ${radians(wheel2_angle_deg)}"/>
  </joint>
  <link name="wheel2_attach_link" />
  <xacro:omni_wheel_set prefix="wheel2" parent="wheel2_attach_link" />

  <joint name="wheel3_attach_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="wheel3_attach_link"/>
    <origin xyz="${0.07*cos(radians(wheel3_angle_deg))} ${0.07*sin(radians(wheel3_angle_deg))} 0.019" rpy="0 0 ${radians(wheel3_angle_deg)}"/>
  </joint>
  <link name="wheel3_attach_link" />
  <xacro:omni_wheel_set prefix="wheel3" parent="wheel3_attach_link" />


  <!-- ros2_control plugin config (keep velocity interfaces compatible with existing controllers) -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="wheel0_motor_shaft_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wheel1_motor_shaft_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wheel2_motor_shaft_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wheel3_motor_shaft_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find gazebo_simulator)/config/controller_omni_robot.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin
      filename="libgz-sim-pose-publisher-system.so"
      name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_model_pose>true</publish_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <update_frequency>50</update_frequency>
    </plugin>
  </gazebo>

</robot>
